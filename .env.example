DATABASE_URL=postgres://comu:comu@localhost:5432/comuapi
REDIS_URL=redis://localhost:6379
COMU_ENV=development
KAI_AUTH_TOKEN=your_token_here
PORT=8080
SYNC_SECRET=your_sync_secret_here
TELEGRAM_TOKEN=your_telegram_bot_token_here
# Public base URL used for the Telegram "Open /app" button
APP_BASE_URL=https://your-domain.example.com
OPEN_METEO_BASE=https://api.open-meteo.com/v1/forecast
TIMEZONE=Asia/Jakarta
AUTO_SYNC=false
# Comma-separated KRL station IDs to skip during schedule sync
SKIPPED_STATIONS=GGL,CKP,BANDARA,PWK
# Trigger background KRL schedule sync when projected (reused) data is served
ON_DEMAND_SYNC_ENABLED=true
# Minimum minutes between on-demand sync triggers
ON_DEMAND_SYNC_MIN_INTERVAL_MINUTES=30
# Telegram user ID to receive token expiry warnings and rotation alerts
ADMIN_TELEGRAM_ID=
# Optional override for startup JSON backfill directory (default auto-detects ./data or /app/data)
BACKFILL_DATA_DIR=
